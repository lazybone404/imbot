      },
      "base_decay_rate": {
        "description": "遗忘速度",
        "type": "float",
        "default": 0.02,
        "hint": "每天衰减的比例。0.02 = 每天淡忘 2%。调到 0 就不会忘"
      },
      "core_limit": {
        "description": "永久不忘的记忆数",
        "type": "int",
        "default": 5,
        "hint": "最高强度的记忆永不衰减，这是上限"
      },
      "owner_core_limit": {
        "description": "关于你的永久记忆",
        "type": "int",
        "default": 3,
        "hint": "专门为你保留的永久记忆配额"
      },
      "owner_decay_mult": {
        "description": "关于你的记忆忘得更慢",
        "type": "float",
        "default": 1.5,
        "hint": "大于 1 就比别人忘得慢。1.5 = 关于你的记忆衰减慢 50%"
      },
      "owner_retrieval_bonus": {
        "description": "更容易想起你的事",
        "type": "float",
        "default": 1.0,
        "hint": "越大越容易在对话中想起和你的过往"
      },
      "consolidation": {
        "description": "启动时整理记忆",
        "type": "bool",
        "default": true,
        "hint": "每次启动时离线整理一次记忆，类似人睡醒后巩固记忆"
      },
      "tot_enabled": {
        "description": "话在嘴边想不起来",
        "type": "bool",
        "default": true,
        "hint": "开启后她有时会觉得「好像记得但想不起来」，更像真人"
      },
      "emotion_residue": {
        "description": "情绪会留下痕迹",
        "type": "bool",
        "default": true,
        "hint": "高强度情绪事件会在记忆中留下印记"
      },
      "allow_user_correction": {
        "description": "你可以纠正她的记忆",
        "type": "bool",
        "default": true,
        "hint": "你说「你记错了」她就会修正"
      }
    }
  },
